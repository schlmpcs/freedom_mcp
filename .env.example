# Freedom24 / Tradernet MCP server credentials.
# Copy this file to ".env" and fill in your values. NEVER commit ".env".
#
# You need EITHER an API key pair (recommended) OR login/password.

# --- Option A: API key (recommended) ---
# Freedom24 web platform -> Settings -> API -> create a key pair.
# PUB_KEY is the public/api key, PRIV_KEY is the secret key used to sign requests.
FREEDOM24_PUB_KEY=
FREEDOM24_PRIV_KEY=

# --- Option B: login / password ---
FREEDOM24_LOGIN=
FREEDOM24_PASSWORD=

# --- Optional ---
# RSA private key (PEM) for the EDS "open security session" flow, if your
# account requires a digital signature to authorize orders. Leave blank if unused.
# Provide the PEM contents inline (use \n for newlines) or an absolute file path.
FREEDOM24_RSA_PRIVATE_KEY=

# Override the API base URL if needed (default below).
FREEDOM24_API_URL=https://freedom24.com/api

# HTTP timeout in seconds (default 15).
FREEDOM24_TIMEOUT=15

# Set to "true" to log/validate orders without sending them.
FREEDOM24_DRY_RUN=false

# MCP server transport (leave as stdio for local dev; set to streamable-http on the droplet)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_BEARER_TOKEN=CHANGEME

# --- Phase 2: Telegram bot / automation worker ---
# Bot token from @BotFather. Secret — keep it out of git.
TELEGRAM_BOT_TOKEN=123456:your-botfather-token
# Your numeric chat ID (the ONLY chat allowed to use the bot / receive pushes).
# Get it by messaging @userinfobot, or from getUpdates after you message your bot.
TELEGRAM_CHAT_ID=000000000
# Alert poll interval, seconds.
BOT_ALERT_POLL_SECONDS=60
# Daily snapshot delivery time, in BOT_SNAPSHOT_TZ (reflects the prior US close).
BOT_SNAPSHOT_TIME=08:00
BOT_SNAPSHOT_TZ=Asia/Karachi
# Pre-market heads-up time, in BOT_PREMARKET_TZ (anchored to the US session).
BOT_PREMARKET_TIME=08:30
BOT_PREMARKET_TZ=America/New_York
# Where the already-relayed alert IDs are persisted (gitignored).
BOT_STATE_PATH=bot_state.json

# --- Phase 3/4: Autonomous agent + evals ---
# Model backend for the agent's decision + judge calls:
#   api         -> use the Anthropic API (requires ANTHROPIC_API_KEY below; pay-as-you-go)
#   claude_code -> use your Claude Max/Pro subscription via the Agent SDK
#                  (run `claude login` once; no API key needed)
AGENT_BACKEND=api
# Only used by the 'api' backend. Leave blank when AGENT_BACKEND=claude_code.
ANTHROPIC_API_KEY=
# Model ids (optional overrides). Defaults: agent=claude-opus-4-7, judge=claude-sonnet-4-6.
AGENT_MODEL=
JUDGE_MODEL=
